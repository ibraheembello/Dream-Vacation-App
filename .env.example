# ============================================================================
# Copy this file to ".env" and adjust values:  cp .env.example .env
# docker compose reads ".env" automatically for variable substitution.
# NEVER commit the real ".env" (it is git-ignored).
# ============================================================================

# --- PostgreSQL ---
POSTGRES_USER=dreamuser
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=dreamvacations

# --- Backend ---
BACKEND_PORT=3001
COUNTRIES_API_BASE_URL=https://restcountries.com/v3.1

# --- Frontend (value is baked into the React bundle at build time) ---
# Point this at the host:port where the backend is published.
REACT_APP_API_URL=http://localhost:3001
FRONTEND_PORT=3000
